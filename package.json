{
  "name": "footy-contacts",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:mobile": "turbo dev --filter=mobile",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "playwright": "^1.59.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0"
    }
  },
  "dependencies": {
    "@sentry/nextjs": "10",
    "@supabase/supabase-js": "^2.49.4",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "node-fetch": "^3.3.2"
  }
}
